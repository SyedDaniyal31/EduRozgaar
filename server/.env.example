PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/edurozgaar

# JWT (Phase-2)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=1h
REFRESH_EXPIRES_IN=7d

# Redis (Phase-6, optional – falls back to in-memory)
REDIS_URL=redis://localhost:6379

# Firebase Cloud Messaging (Phase-6, optional)
# FIREBASE_SERVER_KEY= or use Firebase Admin SDK

# Google OAuth (future)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
