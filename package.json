{
  "name": "edurozgaar-e-portal",
  "version": "1.0.0",
  "description": "EduRozgaar – Pakistan Job & Education E-Portal",
  "private": true,
  "scripts": {
    "dev": "npm run dev --prefix client",
    "client": "cd client && npm run dev",
    "server": "cd server && npm run dev",
    "dev:all": "concurrently -n server,client -c blue,green \"npm run server\" \"npm run client\"",
    "dev-all": "npm run dev:all",
    "build": "npm run build --prefix client",
    "start:server": "npm run start --prefix server",
    "lint": "npm run lint --prefix client && npm run lint --prefix server",
    "format": "prettier --write \"client/src/**/*.{js,jsx,ts,tsx,json,css,md}\" \"server/src/**/*.{js,ts,json,md}\""
  },
  "keywords": ["education", "jobs", "pakistan", "scholarships", "admissions"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^9.1.0",
    "prettier": "^3.2.5"
  }
}
